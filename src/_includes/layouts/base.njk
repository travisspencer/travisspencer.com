<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Not made by AI; made by a human—but with AI help :) -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Travis Spencer — Technologist, Executive, and Architect specializing in identity-driven systems, IAM, and API security.">
  <title>Travis Spencer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>  
  <header>
    <div>
      <a href="#" id="scroll-home-btn" aria-label="Back to top">
        <img src="/me.jpg" alt="Travis Spencer">
      </a>
      <nav aria-label="Primary">
        <ul>
          <li><a href="#achievements">Achievements</a></li>
          <li><a href="#speaking">Speaking</a></li>
          <li><a href="#publications">Publications</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const heroPhoto = document.querySelector("#hero-photo"); 
      const homeBtn = document.querySelector("#scroll-home-btn");
      const header = document.querySelector("header"); // 1. Grab the header element

      if (heroPhoto && homeBtn && header) {
        // 2. Measure the exact pixel height of the header right now
        const headerHeight = header.offsetHeight; 

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) {
              homeBtn.classList.add("visible");
            } else {
              homeBtn.classList.remove("visible");
            }
          });
        }, {
          root: null,
          threshold: 0,
          // 3. Dynamically inject that exact height as a negative margin
          rootMargin: `-${headerHeight}px 0px 0px 0px` 
        });

        observer.observe(heroPhoto);
      }
    });
  </script>
</body>
</html>